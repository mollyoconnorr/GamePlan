<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <springProperty scope="context" name="GAMEPLAN_LOGGING_DIR"
                    source="gameplan.logging.dir" defaultValue="logs"/>
    <springProperty scope="context" name="GAMEPLAN_LOGGING_FILE"
                    source="gameplan.logging.file" defaultValue="${GAMEPLAN_LOGGING_DIR}/gameplan.log"/>

    <property name="CONSOLE_LOG_PATTERN"
              value="%d{HH:mm:ss.SSS} %-5level [req:%X{requestId:-}] [user:%X{principal:-}] %logger{36} - %msg%n"/>
    <property name="FILE_LOG_PATTERN"
              value="%d{HH:mm:ss.SSS} %-5level [req:%X{requestId:-}] [user:%X{principal:-}] %logger{36} - %msg%n"/>

    <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${GAMEPLAN_LOGGING_FILE}</file>
        <encoder>
            <pattern>${FILE_LOG_PATTERN}</pattern>
            <charset>${FILE_LOG_CHARSET}</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${GAMEPLAN_LOGGING_FILE}.%d{yyyy-MM-dd}.%i.gz</fileNamePattern>
            <maxFileSize>${LOGBACK_ROLLINGPOLICY_MAX_FILE_SIZE:-10MB}</maxFileSize>
            <maxHistory>${LOGBACK_ROLLINGPOLICY_MAX_HISTORY:-30}</maxHistory>
            <totalSizeCap>${LOGBACK_ROLLINGPOLICY_TOTAL_SIZE_CAP:-1GB}</totalSizeCap>
        </rollingPolicy>
    </appender>

    <logger name="org.springframework.security" level="INFO"/>
    <logger name="org.springframework.security.oauth2" level="INFO"/>
    <logger name="org.springframework.web" level="INFO"/>

    <springProfile name="dev">
        <logger name="edu.carroll.gameplan" level="DEBUG"/>
    </springProfile>

    <springProfile name="!dev">
        <logger name="edu.carroll.gameplan" level="INFO"/>
    </springProfile>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>
</configuration>
